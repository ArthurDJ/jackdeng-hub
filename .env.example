# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URI=postgresql://user:password@host:5432/dbname

# ─── Payload CMS ────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-payload-secret-here
NEXT_PUBLIC_SERVER_URL=https://jackdeng.cc

# ─── Vercel Blob Storage (Media uploads) ────────────────────────────────────
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# ─── Cloudflare Turnstile (Comment spam protection) ─────────────────────────
# Sitekey is public — safe to share, embedded in browser HTML
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAC2QvkuVUR7bABuA
# Secret Key is server-side only — NEVER commit the real value, add to Vercel env vars
TURNSTILE_SECRET_KEY=your-turnstile-secret-here
